# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# OpenAI (for real AI stylist - optional)
# OPENAI_API_KEY="sk-..."

# Weather API (OpenWeatherMap - optional)
# WEATHER_API_KEY="your-weather-api-key"

# Stripe (for payments - optional)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Mobile API (optional — restrict mobile CORS to a specific origin)
# MOBILE_APP_ORIGIN="https://your-mobile-app.com"

# Web Scraping Configuration
# PROXY_URL="http://your-proxy:port"          # HTTP proxy for web scraping (optional)
# LLM_API_KEY="sk-..."                        # API key for LLM product extraction (OpenAI, Gemini, etc.)
# LLM_API_URL="https://api.openai.com/v1/chat/completions"  # LLM endpoint (defaults to OpenAI)
# LLM_MODEL="gpt-4o-mini"                     # LLM model name (defaults to gpt-4o-mini)
# CRON_SECRET="your-cron-secret"              # Secret to protect the /api/cron/scrape endpoint
