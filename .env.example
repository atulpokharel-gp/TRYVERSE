# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# OpenAI (for real AI stylist - optional)
# OPENAI_API_KEY="sk-..."

# Weather API (OpenWeatherMap - optional)
# WEATHER_API_KEY="your-weather-api-key"

# Stripe (for payments - optional)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Mobile API (optional — restrict mobile CORS to a specific origin)
# MOBILE_APP_ORIGIN="https://your-mobile-app.com"

# Cron Authentication (used to secure /api/cron/* endpoints in production)
# CRON_SECRET="generate-a-random-secret-here"
