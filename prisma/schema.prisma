// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  name                 String?
  password             String?
  image                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  gender               String?
  stylePreference      String?
  bodyType             String?
  sizeCategory         String?
  favoriteBrands       String?         // JSON stored as string in SQLite
  budgetMin            Float?
  budgetMax            Float?
  occasionPreferences  String?         // JSON stored as string in SQLite

  bodyProfile          BodyProfile?
  wardrobeItems        WardrobeItem[]
  chatMessages         ChatMessage[]
  recentSearches       RecentSearch[]
  mobileTokens         MobileToken[]
}

model BodyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  height      Float?
  weight      Float?
  chest       Float?
  waist       Float?
  hips        Float?
  shoulders   Float?
  bodyShape   String?
  sizeCategory String?
  fitNotes    String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id                    String         @id @default(cuid())
  name                  String
  brand                 String
  price                 Float
  originalPrice         Float?
  image                 String
  category              String
  tags                  String?        // JSON stored as string in SQLite
  bodyShapeCompatibility String?       // JSON stored as string in SQLite
  weatherSuitability    String?        // JSON stored as string in SQLite
  occasions             String?        // JSON stored as string in SQLite
  sizes                 String?        // JSON stored as string in SQLite
  colors                String?        // JSON stored as string in SQLite
  source                String?
  rating                Float?
  reviewCount           Int?
  isNew                 Boolean        @default(false)
  isTrending            Boolean        @default(false)

  wardrobeItems         WardrobeItem[]
}

model WardrobeItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  notes     String?
  addedAt   DateTime @default(now())
  category  String   @default("wardrobe") // wishlist / wardrobe / tryLater

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecentSearch {
  id        String   @id @default(cuid())
  userId    String
  query     String
  imageUrl  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MobileToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Phia Brand Models ──

model PhiaBrand {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  logoUrl       String?
  description   String?
  websiteUrl    String?
  category      String?
  sourceUrl     String
  productCount  Int      @default(0)
  firstSeenAt   DateTime @default(now())
  lastScrapedAt DateTime?

  products      PhiaBrandProduct[]

  @@index([category])
}

model PhiaBrandProduct {
  id            String   @id @default(cuid())
  brandId       String
  externalId    String?
  name          String
  price         Float?
  originalPrice Float?
  currency      String   @default("USD")
  imageUrl      String?
  productUrl    String?
  category      String?
  description   String?
  sizes         String?
  colors        String?
  inStock       Boolean  @default(true)
  sourceUrl     String?
  lastSeenAt    DateTime @default(now())

  brand         PhiaBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([category])
}

model BrandScrapeJob {
  id             String    @id @default(cuid())
  jobType        String    @default("full")
  targetUrl      String?
  status         String    @default("pending")
  brandsFound    Int       @default(0)
  productsFound  Int       @default(0)
  pagesScraped   Int       @default(0)
  errorCount     Int       @default(0)
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  logs           BrandScrapeLog[]

  @@index([status])
}

model BrandScrapeLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String
  message   String
  url       String?
  createdAt DateTime @default(now())

  job       BrandScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ── Web Scraping Models ──

model ScrapeSite {
  id          String   @id @default(cuid())
  name        String
  url         String
  brand       String
  category    String   @default("all")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scrapeJobs  ScrapeJob[]
  scrapedProducts ScrapedProduct[]
}

model ScrapedProduct {
  id            String   @id @default(cuid())
  name          String
  brand         String
  category      String
  url           String
  price         Float
  currency      String   @default("USD")
  imageUrl      String
  description   String?
  siteId        String
  scrapedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  site          ScrapeSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([url, siteId])
  @@index([brand])
  @@index([category])
  @@index([siteId])
}

model ScrapeJob {
  id            String   @id @default(cuid())
  siteId        String
  status        String   @default("pending")  // pending | running | completed | failed
  productsFound Int      @default(0)
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  site          ScrapeSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([status])
}
