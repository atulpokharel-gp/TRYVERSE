// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  name                 String?
  password             String?
  image                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  gender               String?
  stylePreference      String?
  bodyType             String?
  sizeCategory         String?
  favoriteBrands       String?         // JSON stored as string in SQLite
  budgetMin            Float?
  budgetMax            Float?
  occasionPreferences  String?         // JSON stored as string in SQLite

  bodyProfile          BodyProfile?
  wardrobeItems        WardrobeItem[]
  chatMessages         ChatMessage[]
  recentSearches       RecentSearch[]
  mobileTokens         MobileToken[]
}

model BodyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  height      Float?
  weight      Float?
  chest       Float?
  waist       Float?
  hips        Float?
  shoulders   Float?
  bodyShape   String?
  sizeCategory String?
  fitNotes    String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id                    String         @id @default(cuid())
  name                  String
  brand                 String
  price                 Float
  originalPrice         Float?
  image                 String
  category              String
  tags                  String?        // JSON stored as string in SQLite
  bodyShapeCompatibility String?       // JSON stored as string in SQLite
  weatherSuitability    String?        // JSON stored as string in SQLite
  occasions             String?        // JSON stored as string in SQLite
  sizes                 String?        // JSON stored as string in SQLite
  colors                String?        // JSON stored as string in SQLite
  source                String?
  rating                Float?
  reviewCount           Int?
  isNew                 Boolean        @default(false)
  isTrending            Boolean        @default(false)

  wardrobeItems         WardrobeItem[]
}

model WardrobeItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  notes     String?
  addedAt   DateTime @default(now())
  category  String   @default("wardrobe") // wishlist / wardrobe / tryLater

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecentSearch {
  id        String   @id @default(cuid())
  userId    String
  query     String
  imageUrl  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MobileToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Phia Brand Scraping ──

model PhiaBrand {
  id            String    @id @default(cuid())
  slug          String    @unique          // URL slug, e.g. "nike"
  name          String                     // Display name, e.g. "Nike"
  logoUrl       String?                    // Brand logo image URL
  description   String?                    // Brand description text
  websiteUrl    String?                    // Brand's own website
  category      String?                    // Category on Phia (e.g. "Luxury", "Streetwear")
  productCount  Int       @default(0)      // Number of products discovered
  sourceUrl     String                     // The Phia page this was scraped from
  firstSeenAt   DateTime  @default(now())  // When we first discovered this brand
  lastScrapedAt DateTime?                  // When we last scraped the detail page
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products      PhiaBrandProduct[]
}

model PhiaBrandProduct {
  id            String    @id @default(cuid())
  brandId       String
  externalId    String?                    // ID from Phia if available
  name          String
  price         Float?
  originalPrice Float?
  currency      String    @default("USD")
  imageUrl      String?
  productUrl    String?                    // Link to product on Phia
  category      String?
  description   String?
  sizes         String?                    // JSON array stored as string
  colors        String?                    // JSON array stored as string
  inStock       Boolean   @default(true)
  sourceUrl     String                     // The page this was scraped from
  firstSeenAt   DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  brand         PhiaBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, name, productUrl])
}

model BrandScrapeJob {
  id            String    @id @default(cuid())
  status        String    @default("pending") // pending | running | completed | failed
  jobType       String    @default("full")    // full | incremental | detail
  targetUrl     String?                       // Specific URL to scrape, null = all
  brandsFound   Int       @default(0)
  productsFound Int       @default(0)
  pagesScraped  Int       @default(0)
  errorCount    Int       @default(0)
  errorMessage  String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  logs          BrandScrapeLog[]
}

model BrandScrapeLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String   @default("info")      // info | warn | error | success
  message   String
  url       String?
  createdAt DateTime @default(now())

  job       BrandScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
